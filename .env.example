# ── YOUR SITE ──────────────────────────────────────────────
# The public URL where this server runs (no trailing slash)
# Local dev:  http://localhost:3000
# Production: https://yourapp.railway.app
BASE_URL=http://localhost:3000

# ── SESSION ─────────────────────────────────────────────────
# Random secret string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_string

# ── SUPABASE ────────────────────────────────────────────────
# From your Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (not anon key — needs write access)

# ── EMBARK / PIONEER ────────────────────────────────────────
# These are Embark's own game client credentials (from PioneerGame.exe)
# Used to exchange platform tokens for Pioneer Bearer JWTs
EMBARK_CLIENT_ID=embark-pioneer
EMBARK_CLIENT_SECRET=+GoAQg2vzgcohjnW0PKtfiMjLfvSTfcjsyJ8YqH3DuE=
EMBARK_AUTH_URL=https://auth.embark.net/oauth2/token
PIONEER_BASE_URL=https://api-gateway.europe.es-pio.net/v1/pioneer

